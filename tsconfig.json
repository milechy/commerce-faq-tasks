{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "lib/**/*.ts", "convex/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist", "commerce-faq-phase7-minimal", "phase12-context", "phase12-context 2", "admin-ui"]
}
