# R2C / RAJIUCE — Environment Variables
# Updated: 2026-04-21 (Phase A Day 7: 13変数追加, stale 2変数削除)
# Copy to .env and fill in values before deploying.

# ==== Core ====
PORT=3100
LOG_LEVEL=info
NODE_ENV=development
LOGS_DIR=logs

# ==== CORS ====
# カンマ区切りで複数オリジン: http://localhost:8080,https://example.com
ALLOWED_ORIGINS=http://localhost:8080
API_BASE_URL=http://localhost:3100

# ==== Database ====
DATABASE_URL=postgres://postgres:pass@127.0.0.1:5434/faq

# ==== Elasticsearch ====
ES_URL=http://localhost:9200
ES_FAQ_INDEX=faq

# ==== Hybrid Search ====
HYBRID_TIMEOUT_MS=300
HYBRID_MOCK_ON_FAILURE=1
LANG_SEARCH_ENABLED=false
RAGSTATS_TOPLEVEL_COMPAT=false

# ==== Cross-encoder ====
CE_MODEL_PATH=
CE_ENGINE=heuristic
CE_VOCAB_PATH=
CE_INPUT_IDS_NAME=input_ids
CE_TOKEN_TYPE_IDS_NAME=token_type_ids
CE_ATTENTION_MASK_NAME=attention_mask
CE_OUTPUT_NAME=logits
CE_OUTPUT_INDEX=0
CE_MAX_BATCH_SIZE=16
CE_MAX_SEQ_LEN=512
CE_MIN_QUERY_CHARS=2
CE_CANDIDATES=20

# ==== Auth — API Key ====
AGENT_API_KEY=
API_KEY_TENANT_ID=
# 複数テナント: JSON配列形式
API_KEY=
API_KEY_2=
API_KEY_2_TENANT_ID=
TENANT_CONFIGS_JSON=
SUPER_ADMIN_BYPASS=false

# ==== Auth — Basic ====
BASIC_USER=
BASIC_PASS=
AGENT_BASIC_USER=
AGENT_BASIC_PASSWORD=
BASIC_AUTH_TENANT_ID=

# ==== Auth — Supabase ====
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WIDGET_JWT_SECRET=
# Admin UI (VITE_ prefix — set in admin-ui/.env.local)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ==== LLM — Primary (Groq) ====
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL_8B=llama-3.1-8b-instant
GROQ_MODEL_70B=llama-3.3-70b-versatile
GROQ_ANSWER_20B_MODEL=llama3-8b-8192
GROQ_ANSWER_120B_MODEL=llama-3.3-70b-versatile
GROQ_PLANNER_20B_MODEL=llama3-8b-8192
GROQ_PLANNER_120B_MODEL=llama-3.3-70b-versatile
GROQ_FAQ_GEN_MODEL=llama-3.3-70b-versatile

# ==== LLM — Alternate (OpenAI-compatible) ====
LLM_API_KEY=
LLM_API_BASE=
LLM_CHAT_MODEL=
LLM_MODEL_20B=
LLM_MODEL_120B=
LLM_FORCE_PLANNER_ROUTE=

# ==== LLM — Planner Feature Flags ====
AGENT_PLANNER_LLM_ENABLED=false
AGENT_PLANNER_MODEL=

# ==== Embeddings (OpenAI) ====
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==== OCR (Qwen) ====
QWEN_API_KEY=

# ==== Judge (Gemini) — Phase45 ====
# GEMINI_API_KEY は src/lib/gemini/client.ts で使用中（削除不可）
GEMINI_API_KEY=your-gemini-api-key
FEEDBACK_AI_MODEL=

# ==== Phase22 — Dialog Flow Control ====
PHASE22_MAX_TURNS=20
PHASE22_MAX_CLARIFY_REPEATS=3
PHASE22_MAX_CONFIRM_REPEATS=2
PHASE22_MAX_SAME_STATE_REPEATS=2
PHASE22_LOOP_WINDOW_TURNS=5
DEFAULT_TENANT_ID=

# ==== Avatar — Phase40-41 ====
PREMIUM_AVATAR_PRICE_CENTS=100
FAL_KEY=
FREEPIK_API_KEY=
LIVEKIT_URL=wss://your-livekit.livekit.cloud
LIVEKIT_WS_URL=wss://your-livekit.livekit.cloud
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret
LIVEKIT_ACCESS_TOKEN=
LIVEKIT_ROOM_PREFIX=r2c-
FISH_AUDIO_API_KEY=your-fish-audio-key
FISH_AUDIO_REFERENCE_ID=
ANAM_API_KEY=
LEONARDO_API_KEY=
# LemonSlice (アバター配信サービス)
LEMON_SLICE_API_TOKEN=
LEMON_SLICE_ENDPOINT=
LEMON_SLICE_READINESS_URL=
LEMON_SLICE_AVATAR_REGISTER_PATH=

# ==== Avatar Storage ====
AVATAR_STORAGE_ROOT=./avatar-uploads
AVATAR_MAX_IMAGE_BYTES=5242880
AVATAR_READINESS_TIMEOUT_MS=5000
AVATAR_ENCRYPTION_KEY=

# ==== Avatar Feature Flags ====
FF_AVATAR_ENABLED=false
FF_AVATAR_FORCE_OFF=false
KILL_SWITCH_AVATAR=false
KILL_SWITCH_REASON=

# ==== Billing — Phase32 ====
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
BILLING_PORTAL_RETURN_URL=https://admin.r2c.biz/billing

# ==== PostHog (Phase A) ====
# R2C運営用 LLM Analytics送信プロジェクト
POSTHOG_PROJECT_API_KEY=phc_xxxx
POSTHOG_API_HOST=https://eu.i.posthog.com

# ==== GA4 / Internal API (Phase A) ====
# GA4 サービスアカウント JSON を Base64 エンコードして設定
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Cloudflare Workers → VPS 間 HMAC-SHA256 認証シークレット
INTERNAL_API_HMAC_SECRET=

# ==== Monitoring ====
SLACK_WEBHOOK_URL=
SENTIMENT_SERVICE_URL=

# ==== Knowledge Encryption ====
KNOWLEDGE_ENCRYPTION_KEY=

# ==== Notion Integration ====
NOTION_API_KEY=
NOTION_DB_FAQ_ID=
NOTION_DB_PRODUCTS_ID=
NOTION_DB_LP_POINTS_ID=
NOTION_DB_TUNING_TEMPLATES_ID=
NOTION_DB_CLARIFY_LOG_ID=

# ==== n8n Webhook Integration ====
N8N_WEBHOOK_URL=
N8N_WEBHOOK_AUTH_HEADER=
N8N_WEBHOOK_TIMEOUT_MS=5000
MARGIN_RATE=0.3

# ==== Search Integrations ====
# OpenClaw (外部検索)
OPENCLAW_ENABLED=false
OPENCLAW_RL_URL=
OPENCLAW_TENANTS=
# OpenViking (外部検索)
OPENVIKING_ENABLED=false
OPENVIKING_URL=
OPENVIKING_TENANTS=
OPENVIKING_TIMEOUT_MS=3000
