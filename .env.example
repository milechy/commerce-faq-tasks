PORT=3100
LOG_LEVEL=info

# ==== CORS ====
# カンマ区切りで複数オリジンを指定可能 例: http://localhost:8080,https://example.com
ALLOWED_ORIGINS=http://localhost:8080

# ==== Data ====
ES_URL=http://localhost:9200
DATABASE_URL=postgres://postgres:pass@127.0.0.1:5434/faq
HYBRID_TIMEOUT_MS=300
HYBRID_MOCK_ON_FAILURE=1

# ==== Cross-encoder ====
CE_MODEL_PATH=
CE_ENGINE=heuristic

# ==== Auth ====
# API Key 認証（推奨）— crypto.randomUUID() 等で生成した値を設定
AGENT_API_KEY=

# テナント紐付け用 ID（API Key / Basic Auth 認証時）
API_KEY_TENANT_ID=
BASIC_AUTH_TENANT_ID=

# 上級: JSON 配列でテナントを明示的に登録（AGENT_API_KEY より優先）
# TENANT_CONFIGS_JSON=

# Basic 認証（DEPRECATED — 移行期間のみ）
AGENT_BASIC_USER=
AGENT_BASIC_PASSWORD=

# ==== Phase24: Monitoring & Alerting ====
SLACK_WEBHOOK_URL=

# ==== Flow ====
PHASE22_MAX_CONFIRM_REPEATS=2
DEFAULT_TENANT_ID=

# ==== Phase27: Qwen OCR ====
QWEN_API_KEY=
OPENAI_API_KEY=