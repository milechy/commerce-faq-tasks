PORT=3000

# ==== CORS ====
# カンマ区切りで複数オリジンを指定可能 例: http://localhost:8080,https://example.com
ALLOWED_ORIGINS=http://localhost:8080
ES_URL=http://localhost:9200
DATABASE_URL=postgres://postgres:pass@127.0.0.1:5434/faq
HYBRID_TIMEOUT_MS=300
HYBRID_MOCK_ON_FAILURE=1
LOG_LEVEL=info
CE_MODEL_PATH=
# ==== Auth for /agent.* ====
# API Key 認証（推奨）
AGENT_API_KEY=

# Basic 認証（オプション）
AGENT_BASIC_USER=
AGENT_BASIC_PASSWORD=

# ==== n8n Webhook ====
# 例: https://n8n.example.com/webhook/agent-events
N8N_WEBHOOK_URL=

# 任意ヘッダ（n8n 側で x-api-key を見る等）
# 例: x-api-key: your-n8n-secret
N8N_WEBHOOK_AUTH_HEADER=

# タイムアウト (ms)
N8N_WEBHOOK_TIMEOUT_MS=2000

# ==== Phase24: Monitoring & Alerting ====
# Slack Incoming Webhook URL（アラート配信先）
SLACK_WEBHOOK_URL=

# テナント紐付け用 ID（API Key / Basic Auth 認証時）
API_KEY_TENANT_ID=
BASIC_AUTH_TENANT_ID=