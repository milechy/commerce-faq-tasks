PORT=3100
LOG_LEVEL=info

# ==== CORS ====
# カンマ区切りで複数オリジンを指定可能 例: http://localhost:8080,https://example.com
ALLOWED_ORIGINS=http://localhost:8080

# ==== Data ====
ES_URL=http://localhost:9200
DATABASE_URL=postgres://postgres:pass@127.0.0.1:5434/faq
HYBRID_TIMEOUT_MS=300
HYBRID_MOCK_ON_FAILURE=1

# ==== Cross-encoder ====
CE_MODEL_PATH=
CE_ENGINE=heuristic

# ==== Auth ====
# API Key 認証（推奨）— crypto.randomUUID() 等で生成した値を設定
AGENT_API_KEY=

# テナント紐付け用 ID（API Key / Basic Auth 認証時）
API_KEY_TENANT_ID=
BASIC_AUTH_TENANT_ID=

# 上級: JSON 配列でテナントを明示的に登録（AGENT_API_KEY より優先）
# TENANT_CONFIGS_JSON=

# Basic 認証（DEPRECATED — 移行期間のみ）
AGENT_BASIC_USER=
AGENT_BASIC_PASSWORD=

# ==== Phase24: Monitoring & Alerting ====
SLACK_WEBHOOK_URL=

# ==== Flow ====
PHASE22_MAX_CONFIRM_REPEATS=2
DEFAULT_TENANT_ID=

# ==== Phase27: Qwen OCR ====
QWEN_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==== Auth (Supabase) ====
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Admin UI用 (VITE_ prefix)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ==== LLM (Groq) ====
GROQ_API_KEY=gsk_xxxx
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_8B=llama-3.1-8b-instant
GROQ_MODEL_70B=llama-3.3-70b-versatile

# ==== Judge (Gemini) — Phase45 ====
GEMINI_API_KEY=your-gemini-api-key
JUDGE_AUTO_EVALUATE=true
JUDGE_SCORE_THRESHOLD=60

# ==== Avatar — Phase40-41 ====
LIVEKIT_URL=wss://your-livekit.livekit.cloud
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret
FISH_AUDIO_API_KEY=your-fish-audio-key
FISH_AUDIO_REFERENCE_ID=
LEMONSLICE_API_KEY=your-lemonslice-key
LEMONSLICE_AGENT_ID=

# ==== Storage (Supabase) ====
SUPABASE_STORAGE_URL=https://YOUR_PROJECT.supabase.co/storage/v1
SUPABASE_BUCKET_BOOK_PDFS=book-pdfs

# ==== Billing — Phase32 ====
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ==== Avatar Idle Prompt (Phase45+) ====
AVATAR_IDLE_PROMPT=a friendly person smiling and nodding gently