PORT=3100
LOG_LEVEL=info
NODE_ENV=production

# ==== CORS ====
ALLOWED_ORIGINS=http://65.108.159.161,http://65.108.159.161:5173

# ==== Data (VPS localhost) ====
ES_URL=http://localhost:9200
DATABASE_URL=postgres://postgres:CHANGE_ME@127.0.0.1:5432/faq
HYBRID_TIMEOUT_MS=300
HYBRID_MOCK_ON_FAILURE=0

# ==== Cross-encoder ====
CE_ENGINE=heuristic

# ==== Auth ====
AGENT_API_KEY=CHANGE_ME
API_KEY_TENANT_ID=partner

# TENANT_CONFIGS_JSON (recommended for production — overrides AGENT_API_KEY)
# Generate hash: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_KEY').digest('hex'))"
# TENANT_CONFIGS_JSON=[{"tenantId":"partner","name":"Partner","plan":"growth","features":{"avatar":false,"voice":false,"rag":true},"security":{"apiKeyHash":"CHANGE_ME","hashAlgorithm":"sha256","allowedOrigins":["http://65.108.159.161","http://65.108.159.161:5173"],"rateLimit":60,"rateLimitWindowMs":60000},"enabled":true}]

# ==== Monitoring ====
SLACK_WEBHOOK_URL=

# ==== Flow ====
PHASE22_MAX_CONFIRM_REPEATS=2
